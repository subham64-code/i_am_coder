# Server environment (copy from root .env.example)
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1

JWT_SECRET=dev_jwt_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
OTP_EXPIRES_MIN=10

DATABASE_URL="mongodb+srv://root:rootpassword@localhost:27017/iamcoder?retryWrites=true&w=majority"
MYSQL_URL="mysql://root:rootpassword@localhost:3306/iamcoder"
REDIS_URL=redis://localhost:6379

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="I AM CODER <no-reply@iamcoder.dev>"

# Resend (preferred email provider) — https://resend.com
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=onboarding@resend.dev
# Brevo (SMTP relay fallback) — https://brevo.com
BREVO_API_KEY=your_brevo_smtp_key
BREVO_SMTP_USER=apikey

# Predefined admin emails allowed to OTP-login to the admin panel (comma-separated)
ADMIN_EMAILS=admin@iamcoder.dev

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=iamcoder
