# I AM CODER — environment variables (root reference copy).
# Copy values into ./client/.env.local and ./server/.env as needed.

# ---------- Server (Express + Prisma) ----------
# App
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1

# Security
JWT_SECRET=change_me_super_secret_jwt
JWT_REFRESH_SECRET=change_me_super_secret_refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
OTP_EXPIRES_MIN=10

# MongoDB (primary data)
DATABASE_URL="mongodb+srv://<user>:<pass>@cluster0.mongodb.net/iamcoder?retryWrites=true&w=majority"

# MySQL (relational: applications, records, audit)
MYSQL_URL="mysql://<user>:<pass>@<host>:3306/iamcoder"

# Redis (rate limit / cache / realtime ready)
REDIS_URL=redis://localhost:6379

# Mail (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="I AM CODER <no-reply@iamcoder.dev>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=iamcoder

# Frontend public API base (used by client at build/runtime)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
